---
import Section from "./Section.astro";
import Button from "./Button.astro";

interface Props {
	title?: string;
	subtitle?: string;
	ctaText?: string;
	ctaHref?: string;
}

const {
	title = "Frontend Engineer",
	subtitle = "Building high-performance, accessible, and beautiful interfaces — with meticulous attention to every pixel and interaction.",
	ctaText = "View Projects",
	ctaHref = "/projects"
} = Astro.props;

const roles = ["Frontend Engineer", "UI Architect", "React Specialist", "Design Systems"];
---

<Section paddingBlock="large" class="hero">
	<div class="hero-container">
		<div class="hero-eyebrow">
			<span class="hero-tag">Available for work</span>
			<span class="hero-dot" aria-hidden="true"></span>
		</div>

		<div class="hero-content">
			<h1 class="hero-title">
				<span class="hero-line hero-line--1">Crafting</span>
				<span class="hero-line hero-line--2">
					<span class="hero-typewriter" aria-label={title} id="hero-typewriter"></span>
					<span class="hero-cursor" aria-hidden="true">|</span>
				</span>
				<span class="hero-line hero-line--3">Experiences</span>
			</h1>
			<p class="hero-subtitle">{subtitle}</p>
			<div class="hero-actions">
				<Button href={ctaHref} size="large">{ctaText}</Button>
				<Button href="/services" variant="outline" size="large">My Services</Button>
			</div>
		</div>

		<div class="hero-decoration" aria-hidden="true">
			<div class="code-block">
				<div class="code-line"><span class="c-keyword">const</span> <span class="c-var">dev</span> <span class="c-op">=</span> <span class="c-bracket">&#123;</span></div>
				<div class="code-line">  <span class="c-prop">name</span><span class="c-op">:</span> <span class="c-string">"JD"</span><span class="c-op">,</span></div>
				<div class="code-line">  <span class="c-prop">stack</span><span class="c-op">:</span> <span class="c-bracket">[</span><span class="c-string">"React"</span><span class="c-op">,</span> <span class="c-string">"Astro"</span><span class="c-bracket">]</span><span class="c-op">,</span></div>
				<div class="code-line">  <span class="c-prop">focus</span><span class="c-op">:</span> <span class="c-string">"performance"</span></div>
				<div class="code-line"><span class="c-bracket">&#125;</span></div>
			</div>
			<div class="metric-badge metric-badge--1">
				<span class="metric-value">99</span>
				<span class="metric-label">Lighthouse</span>
			</div>
			<div class="metric-badge metric-badge--2">
				<span class="metric-value">&lt;1s</span>
				<span class="metric-label">LCP</span>
			</div>
		</div>
	</div>
</Section>

<script>
	const roles = ["Frontend Engineer", "UI Architect", "React Specialist", "Design Systems"];
	const el = document.getElementById("hero-typewriter");
	if (el) {
		let roleIdx = 0;
		let charIdx = 0;
		let deleting = false;
		let pauseTimer: ReturnType<typeof setTimeout> | null = null;

		function tick() {
			const current = roles[roleIdx];
			if (!deleting) {
				el.textContent = current.slice(0, charIdx + 1);
				charIdx++;
				if (charIdx === current.length) {
					deleting = true;
					pauseTimer = setTimeout(tick, 2200);
					return;
				}
			} else {
				el.textContent = current.slice(0, charIdx - 1);
				charIdx--;
				if (charIdx === 0) {
					deleting = false;
					roleIdx = (roleIdx + 1) % roles.length;
					pauseTimer = setTimeout(tick, 400);
					return;
				}
			}
			setTimeout(tick, deleting ? 55 : 90);
		}

		setTimeout(tick, 600);
	}
</script>

<style>
	/* ====================================================
	   DESIGN TOKEN ANNOTATIONS
	   The following values are candidates for the design system:
	   - --color-accent-ink: #0a0a0f (ultra-dark bg for code blocks)
	   - --color-text-muted: rgba(text-primary, 0.5) (for eyebrow/tag)
	   - --border-radius-pill: 9999px (for pill/tag shapes)
	   - --animation-duration-fast: 200ms
	   - --animation-duration-normal: 400ms
	   ==================================================== */

	.hero {
		/* DS NOTE: consider --color-background-hero for gradient variant */
		background: linear-gradient(
			135deg,
			var(--color-background-primary) 0%,
			color-mix(in srgb, var(--color-primary) 5%, var(--color-background-primary)) 100%
		);
		overflow: hidden;
	}

	.hero-container {
		display: grid;
		grid-template-columns: 1fr auto;
		grid-template-rows: auto 1fr;
		gap: var(--spacing-32);
		max-width: 1200px;
		margin: 0 auto;
		padding: var(--spacing-48) var(--spacing-24);
		align-items: center;
	}

	.hero-eyebrow {
		grid-column: 1 / -1;
		display: flex;
		align-items: center;
		gap: var(--spacing-12);
		animation: fade-up 0.6s ease both;
	}

	.hero-tag {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-8);
		padding: var(--spacing-4) var(--spacing-12);
		/* DS NOTE: --border-radius-pill: 9999px candidate */
		border-radius: 9999px;
		border: 1px solid color-mix(in srgb, var(--color-primary) 40%, transparent);
		background: color-mix(in srgb, var(--color-primary) 8%, transparent);
		color: var(--color-primary);
		font-size: var(--font-size-200);
		font-weight: var(--font-weight-medium);
		font-family: var(--font-family-mono);
		letter-spacing: 0.05em;
	}

	.hero-tag::before {
		content: "";
		display: inline-block;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--color-success);
		/* DS NOTE: --color-success-glow animation candidate */
		animation: pulse-dot 2s ease-in-out infinite;
	}

	.hero-dot {
		display: none;
	}

	.hero-content {
		grid-column: 1;
		animation: fade-up 0.7s ease 0.1s both;
	}

	.hero-title {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin-bottom: var(--spacing-32);
		/* DS NOTE: --font-size-display: clamp(2.5rem, 7vw, 5.5rem) candidate */
		font-size: clamp(2.5rem, 7vw, 5.5rem);
		font-weight: var(--font-weight-bold);
		line-height: 1.05;
		letter-spacing: -0.03em;
	}

	.hero-line {
		display: block;
	}

	.hero-line--1 {
		color: var(--color-text-primary);
		opacity: 0.45;
		font-weight: 300;
	}

	.hero-line--2 {
		color: var(--color-primary);
		min-height: 1.1em;
	}

	.hero-line--3 {
		color: var(--color-text-primary);
		opacity: 0.45;
		font-weight: 300;
	}

	.hero-typewriter {
		display: inline;
	}

	.hero-cursor {
		display: inline-block;
		color: var(--color-primary);
		opacity: 1;
		animation: blink 1.1s step-start infinite;
		font-weight: 300;
		margin-left: 2px;
	}

	.hero-subtitle {
		font-size: var(--font-size-400);
		color: var(--color-base-gray-500);
		line-height: var(--font-line-height-relaxed);
		max-width: 520px;
		margin-bottom: var(--spacing-48);
	}

	.hero-actions {
		display: flex;
		gap: var(--spacing-16);
		flex-wrap: wrap;
	}

	/* Decoration / code block */
	.hero-decoration {
		grid-column: 2;
		grid-row: 2;
		position: relative;
		animation: fade-up 0.7s ease 0.25s both;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.code-block {
		/* DS NOTE: --color-surface-code candidate for code block bg */
		background: color-mix(in srgb, var(--color-text-primary) 4%, var(--color-background-secondary));
		border: 1px solid color-mix(in srgb, var(--color-text-primary) 10%, transparent);
		border-radius: var(--spacing-8);
		padding: var(--spacing-24) var(--spacing-32);
		font-family: var(--font-family-mono);
		font-size: var(--font-size-300);
		line-height: 1.8;
		white-space: nowrap;
		position: relative;
	}

	.code-block::before {
		content: "● ● ●";
		display: block;
		font-size: 0.5rem;
		letter-spacing: 4px;
		color: color-mix(in srgb, var(--color-text-primary) 30%, transparent);
		margin-bottom: var(--spacing-12);
		padding-bottom: var(--spacing-12);
		border-bottom: 1px solid color-mix(in srgb, var(--color-text-primary) 10%, transparent);
	}

	.c-keyword { color: #c792ea; }
	.c-var { color: var(--color-primary); }
	.c-prop { color: #82aaff; }
	.c-string { color: #c3e88d; }
	.c-op { color: var(--color-base-gray-500); }
	.c-bracket { color: #ffcb6b; }

	/* DS NOTE: code syntax colors as a set: --color-syntax-* tokens candidate */

	.metric-badge {
		position: absolute;
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: var(--spacing-8) var(--spacing-12);
		background: var(--color-background-primary);
		border: 1px solid color-mix(in srgb, var(--color-primary) 30%, transparent);
		border-radius: var(--spacing-8);
		box-shadow: 0 8px 24px rgba(0,0,0,0.12);
	}

	.metric-value {
		font-size: var(--font-size-600);
		font-weight: var(--font-weight-bold);
		color: var(--color-primary);
		line-height: 1;
		font-family: var(--font-family-mono);
	}

	.metric-label {
		font-size: var(--font-size-100);
		color: var(--color-base-gray-500);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-family: var(--font-family-mono);
	}

	.metric-badge--1 {
		top: -16px;
		right: -16px;
		animation: float 3s ease-in-out infinite;
	}

	.metric-badge--2 {
		bottom: -16px;
		left: -16px;
		animation: float 3s ease-in-out 1.5s infinite;
	}

	/* Keyframes */
	@keyframes fade-up {
		from { opacity: 0; transform: translateY(20px); }
		to   { opacity: 1; transform: translateY(0); }
	}

	@keyframes blink {
		0%, 100% { opacity: 1; }
		50%       { opacity: 0; }
	}

	@keyframes pulse-dot {
		0%, 100% { opacity: 1; transform: scale(1); }
		50%       { opacity: 0.6; transform: scale(0.85); }
	}

	@keyframes float {
		0%, 100% { transform: translateY(0); }
		50%       { transform: translateY(-8px); }
	}

	/* Responsive */
	@media (max-width: 900px) {
		.hero-container {
			grid-template-columns: 1fr;
			grid-template-rows: auto;
		}

		.hero-decoration {
			grid-column: 1;
			grid-row: 3;
			justify-content: flex-start;
		}

		.metric-badge--1 { top: -12px; right: auto; left: 60%; }
		.metric-badge--2 { bottom: -12px; left: auto; right: 0; }
	}

	@media (max-width: 600px) {
		.hero-title {
			font-size: clamp(2rem, 10vw, 2.75rem);
		}

		.hero-decoration {
			display: none;
		}
	}
</style>
