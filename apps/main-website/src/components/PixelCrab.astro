---
interface Properties {
	size?: number;
	class?: string;
}

const { size = 24, class: className } = Astro.props;
---

<!--
  Pixel crab icon — uses currentColor so it automatically adapts to
  the active color scheme via the page's CSS custom properties.
  ViewBox is 24×24; all coordinates scaled from the original 32×32 by ×0.75.
-->
<svg
	xmlns="http://www.w3.org/2000/svg"
	viewBox="2.25 2.25 19.5 13.5"
	width={size}
	height={size}
	aria-hidden="true"
	class={className}
	fill="currentColor"
>
	<!-- Body -->
	<rect x="7.5" y="7.5" width="9" height="6" />
	<rect x="8.25" y="6.75" width="7.5" height="0.75" />
	<rect x="8.25" y="13.5" width="7.5" height="0.75" />

	<!-- Left claw -->
	<rect x="3.75" y="3" width="5.25" height="3" />
	<rect x="6" y="6" width="1.5" height="1.5" />

	<!-- Right claw -->
	<rect x="15" y="3" width="5.25" height="3" />
	<rect x="16.5" y="6" width="1.5" height="1.5" />

	<!-- Left legs -->
	<rect x="4.5" y="8.25" width="3" height="0.75" />
	<rect x="3" y="7.5" width="1.5" height="0.75" />
	<rect x="4.5" y="10.5" width="3" height="0.75" />
	<rect x="3" y="9.75" width="1.5" height="0.75" />
	<rect x="4.5" y="12.75" width="3" height="0.75" />
	<rect x="3" y="12" width="1.5" height="0.75" />

	<!-- Right legs -->
	<rect x="16.5" y="8.25" width="3" height="0.75" />
	<rect x="19.5" y="7.5" width="1.5" height="0.75" />
	<rect x="16.5" y="10.5" width="3" height="0.75" />
	<rect x="19.5" y="9.75" width="1.5" height="0.75" />
	<rect x="16.5" y="12.75" width="3" height="0.75" />
	<rect x="19.5" y="12" width="1.5" height="0.75" />

	<!-- Antennae -->
	<rect x="8.25" y="5.25" width="0.75" height="1.5" />
	<rect x="15" y="5.25" width="0.75" height="1.5" />

	<!-- Eyes: punched out with background color -->
	<rect x="9.75" y="7.5" width="0.75" height="0.75" fill="var(--color-background-primary)" />
	<rect x="13.5" y="7.5" width="0.75" height="0.75" fill="var(--color-background-primary)" />

	<!-- Claw eye holes -->
	<rect x="5.25" y="4.5" width="2.25" height="0.75" fill="var(--color-background-primary)" />
	<rect x="16.5" y="4.5" width="2.25" height="0.75" fill="var(--color-background-primary)" />
</svg>
