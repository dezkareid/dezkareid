---
import Card from "./Card.astro";
import Button from "./Button.astro";
import type { CollectionEntry } from 'astro:content';

interface Properties {
	service: CollectionEntry<'services'>;
}

const { service } = Astro.props;
const { title, description, icon, cta } = service.data;
---

<Card class="service-card">
	<!-- Stretched link covers the full card; contact button sits above it via z-index -->
	<a class="card-link" href={`/services/${service.slug}`} aria-label={`Learn about ${title}`}></a>

	<div class="service-header">
		<span class="service-icon" aria-hidden="true">{icon || "⚙️"}</span>
		<h3 class="service-title">{title}</h3>
	</div>
	<p class="service-description">{description}</p>
	<div class="service-footer">
		<div class="contact-btn-wrap">
			<Button variant="outline" size="sm" data-contact-btn>{cta || "Get in touch"}</Button>
		</div>
	</div>
</Card>

<script>
	for (const button of document.querySelectorAll('[data-contact-btn]')) {
	button.addEventListener('click', (event) => {
		event.preventDefault();
		event.stopPropagation();
		const target = document.querySelector('#contact');
		if (target) target.scrollIntoView({ behavior: 'smooth' });
	});
}
</script>

<style>
	/* ====================================================
	   DESIGN TOKEN ANNOTATIONS
	   - --color-icon-bg: color-mix(primary, bg-secondary) for icon containers
	   - --size-icon-lg: 3rem for large decorative icons
	   ==================================================== */

	.service-card {
		height: 100%;
		display: flex;
		flex-direction: column;
		position: relative;
		overflow: hidden;
		cursor: pointer;
	}

	/* Stretched link — covers the full card */
	.card-link {
		position: absolute;
		inset: 0;
		z-index: 1;
	}

	.service-card::before {
		/* Top accent bar — DS NOTE: --color-accent-bar candidate */
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: linear-gradient(
			90deg,
			var(--color-primary),
			color-mix(in srgb, var(--color-primary) 40%, transparent)
		);
		border-radius: var(--spacing-8) var(--spacing-8) 0 0;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.service-card:hover::before {
		opacity: 1;
	}

	.service-header {
		display: flex;
		align-items: center;
		gap: var(--spacing-12);
		margin-bottom: var(--spacing-12);
	}

	.service-icon {
		font-size: var(--font-size-700);
		line-height: 1;
		flex-shrink: 0;
	}

	.service-title {
		font-size: var(--font-size-500);
		margin: 0;
		color: var(--color-text-primary);
		letter-spacing: -0.01em;
	}

	.service-description {
		font-size: var(--font-size-300);
		/* Use text-primary for sufficient contrast on secondary backgrounds */
		color: var(--color-text-primary);
		opacity: 0.75;
		margin-bottom: var(--spacing-24);
		flex: 1;
		line-height: var(--font-line-height-relaxed);
	}

	.service-footer {
		margin-top: auto;
		display: flex;
		flex-direction: column;
		gap: var(--spacing-8);
	}

	.contact-btn-wrap {
		position: relative;
		z-index: 2;
	}
</style>
