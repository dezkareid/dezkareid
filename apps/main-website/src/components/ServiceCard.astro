---
import Card from "./Card.astro";
import type { CollectionEntry } from 'astro:content';

interface Props {
	service: CollectionEntry<'services'>;
}

const { service } = Astro.props;
const { title, description, icon } = service.data;
---

<Card class="service-card">
	<div class="service-header">
		<span class="service-icon" aria-hidden="true">{icon || "⚙️"}</span>
		<h3 class="service-title">{title}</h3>
	</div>
	<p class="service-description">{description}</p>
	<div class="service-footer">
		<a href={`/services/${service.slug}`} class="learn-more">
			<span>Learn about {title}</span>
			<span class="learn-more-arrow" aria-hidden="true">→</span>
		</a>
	</div>
</Card>

<style>
	/* ====================================================
	   DESIGN TOKEN ANNOTATIONS
	   - --color-icon-bg: color-mix(primary, bg-secondary) for icon containers
	   - --size-icon-lg: 3rem for large decorative icons
	   ==================================================== */

	.service-card {
		height: 100%;
		display: flex;
		flex-direction: column;
		position: relative;
		overflow: hidden;
	}

	.service-card::before {
		/* Top accent bar — DS NOTE: --color-accent-bar candidate */
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: linear-gradient(
			90deg,
			var(--color-primary),
			color-mix(in srgb, var(--color-primary) 40%, transparent)
		);
		border-radius: var(--spacing-8) var(--spacing-8) 0 0;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.service-card:hover::before {
		opacity: 1;
	}

	.service-header {
		display: flex;
		align-items: center;
		gap: var(--spacing-12);
		margin-bottom: var(--spacing-12);
	}

	.service-icon {
		font-size: var(--font-size-700);
		line-height: 1;
		flex-shrink: 0;
	}

	.service-title {
		font-size: var(--font-size-500);
		margin: 0;
		color: var(--color-text-primary);
		letter-spacing: -0.01em;
	}

	.service-description {
		font-size: var(--font-size-300);
		color: var(--color-base-gray-500);
		margin-bottom: var(--spacing-24);
		flex: 1;
		line-height: var(--font-line-height-relaxed);
	}

	.service-footer {
		margin-top: auto;
	}

	.learn-more {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-8);
		color: var(--color-primary);
		font-weight: var(--font-weight-medium);
		font-size: var(--font-size-300);
		text-decoration: none;
		transition: gap 0.2s ease;
	}

	.learn-more-arrow {
		transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.learn-more:hover {
		text-decoration: none;
	}

	.learn-more:hover .learn-more-arrow {
		transform: translateX(4px);
	}
</style>
