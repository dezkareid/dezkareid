---
import Card from "./Card.astro";
import type { CollectionEntry } from 'astro:content';

interface Properties {
	project: CollectionEntry<'projects'>;
	index?: number;
}

const { project, index = 0 } = Astro.props;
const { title, description, techStack, image, type } = project.data;

const number_ = String(index + 1).padStart(2, "0");

const typeLabel: Record<string, string> = {
	personal: "Personal",
	work: "Work",
	contribution: "Contribution",
};
---

<Card class="project-card">
	<a class="card-link" href={`/projects/${project.slug}`} aria-label={`View ${title}`}></a>

	{image && (
		<div class="project-image">
			<img src={image} alt={`${title} preview`} width="600" height="400" loading="lazy" decoding="async" />
		</div>
	)}

	<div class="project-content">
		<div class="project-meta-top">
			<span class="project-number" aria-hidden="true">{number_}</span>
			<span class="project-type-badge" data-type={type}>{typeLabel[type]}</span>
		</div>

		<h3 class="project-title">{title}</h3>
		<p class="project-description">{description}</p>

		<div class="project-tech-stack">
			{techStack.map((tech) => (
				<span class="tech-tag">{tech}</span>
			))}
		</div>
	</div>
</Card>

<style>
	/* ====================================================
	   DESIGN TOKEN ANNOTATIONS
	   - --color-text-number: large muted counter color
	     Currently: color-mix(in srgb, primary 12%, transparent)
	   - --font-size-display-number: 5rem for decorative counters
	   ==================================================== */

	.project-card {
		height: 100%;
		display: flex;
		flex-direction: column;
		position: relative;
		overflow: hidden;
		cursor: pointer;
	}

	/* Stretched link — covers the full card */
	.card-link {
		position: absolute;
		inset: 0;
		z-index: 1;
	}

	.project-image {
		width: 100%;
		aspect-ratio: 3 / 2;
		overflow: hidden;
		flex-shrink: 0;
	}

	.project-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.3s ease;
	}

	.project-card:hover .project-image img {
		transform: scale(1.03);
	}

	.project-content {
		display: flex;
		flex-direction: column;
		flex: 1;
		padding-top: var(--spacing-16);
		position: relative;
	}

	.project-meta-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: var(--spacing-12);
	}

	.project-number {
		/* DS NOTE: --font-size-display-number candidate */
		font-size: 2.5rem;
		font-weight: var(--font-weight-bold);
		font-family: var(--font-family-mono);
		line-height: 1;
		/* DS NOTE: --color-text-number candidate */
		color: color-mix(in srgb, var(--color-primary) 12%, transparent);
		pointer-events: none;
		user-select: none;
		transition: color 0.25s ease;
	}

	.project-card:hover .project-number {
		color: color-mix(in srgb, var(--color-primary) 20%, transparent);
	}

	.project-type-badge {
		font-size: var(--font-size-100);
		font-family: var(--font-family-mono);
		font-weight: var(--font-weight-medium);
		letter-spacing: 0.05em;
		text-transform: uppercase;
		padding: var(--spacing-4) var(--spacing-8);
		border-radius: 9999px;
		position: relative;
		z-index: 2;
	}

	.project-type-badge[data-type="personal"] {
		background-color: color-mix(in srgb, var(--color-primary) 12%, transparent);
		/* light-dark ensures readable contrast on both themes */
		color: light-dark(#1d4ed8, #93c5fd);
		border: 1px solid color-mix(in srgb, var(--color-primary) 30%, transparent);
	}

	.project-type-badge[data-type="work"] {
		background-color: color-mix(in srgb, #22c55e 12%, transparent);
		color: light-dark(#15803d, #86efac);
		border: 1px solid color-mix(in srgb, #22c55e 30%, transparent);
	}

	.project-type-badge[data-type="contribution"] {
		background-color: color-mix(in srgb, #f59e0b 12%, transparent);
		color: light-dark(#92400e, #fcd34d);
		border: 1px solid color-mix(in srgb, #f59e0b 30%, transparent);
	}

	.project-title {
		font-size: var(--font-size-500);
		margin-bottom: var(--spacing-12);
		color: var(--color-text-primary);
		letter-spacing: -0.01em;
		line-height: var(--font-line-height-tight);
	}

	.project-description {
		font-size: var(--font-size-300);
		color: var(--color-text-primary);
		opacity: 0.75;
		margin-bottom: var(--spacing-24);
		flex: 1;
		line-height: var(--font-line-height-relaxed);
	}

	.project-tech-stack {
		display: flex;
		gap: var(--spacing-8);
		flex-wrap: wrap;
	}

	.tech-tag {
		background-color: color-mix(in srgb, var(--color-primary) 8%, var(--color-background-secondary));
		border: 1px solid color-mix(in srgb, var(--color-primary) 20%, transparent);
		padding: var(--spacing-4) var(--spacing-8);
		/* DS NOTE: --border-radius-pill: 9999px candidate */
		border-radius: 9999px;
		font-size: var(--font-size-100);
		font-weight: var(--font-weight-medium);
		color: var(--color-primary);
		font-family: var(--font-family-mono);
		letter-spacing: 0.02em;
	}
</style>
