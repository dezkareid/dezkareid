---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/Section.astro';
import Button from '../../components/Button.astro';

export async function getStaticPaths() {
	const services = await getCollection('services');
	return services.map((service) => ({
		params: { slug: service.slug },
		props: { service },
	}));
}

const { service } = Astro.props;
const { Content } = await service.render();
const { title, description, icon } = service.data;
---

<Layout title={`${title} | Services`}>
	<Section>
		<div class="container">
			<nav class="breadcrumb">
				<a href="/services">← Back to Services</a>
			</nav>

			<header class="service-header">
				<div class="service-icon" aria-hidden="true">
					{icon || "⚙️"}
				</div>
				<h1 class="service-title">{title}</h1>
				<p class="service-description">{description}</p>
				<Button href="mailto:example@example.com" size="large">Inquire About This Service</Button>
			</header>

			<hr class="divider" />

			<div class="service-content">
				<Content />
			</div>
		</div>
	</Section>
</Layout>

<style>
	.container {
		max-width: 800px;
		margin: 0 auto;
	}

	.breadcrumb {
		margin-bottom: var(--spacing-32);
	}

	.service-header {
		text-align: center;
		margin-bottom: var(--spacing-48);
	}

	.service-icon {
		font-size: var(--font-size-900);
		margin-bottom: var(--spacing-24);
	}

	.service-title {
		font-size: var(--font-size-800);
		margin-bottom: var(--spacing-16);
	}

	.service-description {
		font-size: var(--font-size-500);
		color: var(--color-base-gray-500);
		margin-bottom: var(--spacing-48);
		line-height: var(--font-line-height-relaxed);
		max-width: 600px;
		margin-inline: auto;
	}

	.divider {
		border: 0;
		border-top: 1px solid var(--color-base-gray-100);
		margin: var(--spacing-48) 0;
	}

	.service-content {
		font-size: var(--font-size-400);
		line-height: var(--font-line-height-relaxed);
		color: var(--color-text-primary);
	}

	.service-content :global(h2) {
		font-size: var(--font-size-600);
		margin: var(--spacing-48) 0 var(--spacing-24);
	}

	.service-content :global(p) {
		margin-bottom: var(--spacing-24);
	}

	.service-content :global(ul) {
		margin-bottom: var(--spacing-24);
		padding-left: var(--spacing-24);
	}
</style>
