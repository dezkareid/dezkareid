---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/Section.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projectsCollection = await getCollection('projects');
const allProjects = projectsCollection.toSorted((a, b) => a.data.order - b.data.order);
---

<Layout title="Projects | Frontend Developer Portfolio">
	<Section>
		<div class="container">
			<span class="page-label">Portfolio</span>
			<h1 class="page-title">My Projects</h1>
			<p class="page-description">A collection of my recent work, ranging from design systems to performance audits.</p>

			<div class="grid">
				{allProjects.map((project, index) => (
					<ProjectCard project={project} index={index} />
				))}
			</div>
		</div>
	</Section>
</Layout>

<style>
	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding-inline: var(--spacing-24);
	}

	@media (min-width: 90rem) {
		.container {
			padding-inline: 0;
		}
	}

	.page-label {
		display: block;
		font-size: var(--font-size-100);
		font-family: var(--font-family-mono);
		font-weight: var(--font-weight-medium);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-primary);
		margin-bottom: var(--spacing-8);
	}

	.page-title {
		font-size: var(--font-size-800);
		margin-bottom: var(--spacing-16);
		letter-spacing: -0.03em;
	}

	.page-description {
		font-size: var(--font-size-400);
		color: var(--color-base-gray-500);
		margin-bottom: var(--spacing-64);
		max-width: 600px;
		line-height: var(--font-line-height-relaxed);
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: var(--spacing-32);
	}

	@media (max-width: 600px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
