---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/Section.astro';
import Button from '../../components/Button.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { title, description, techStack, githubUrl, liveUrl } = project.data;
---

<Layout title={`${title} | Projects`}>
	<Section>
		<div class="container">
			<nav class="breadcrumb">
				<a href="/projects">← Back to Projects</a>
			</nav>

			<header class="project-header">
				<h1 class="project-title">{title}</h1>
				<p class="project-description">{description}</p>
				
				<div class="project-meta">
					<div class="tech-stack">
						{techStack.map((tech) => (
							<span class="tech-tag">{tech}</span>
						))}
					</div>
					<div class="project-links">
						{githubUrl && <Button href={githubUrl} target="_blank" rel="noopener noreferrer">GitHub Repo</Button>}
						{liveUrl && <Button href={liveUrl} variant="success" target="_blank" rel="noopener noreferrer">Live Demo</Button>}
					</div>
				</div>
			</header>

			<hr class="divider" />

			<div class="project-content">
				<Content />
			</div>
		</div>
	</Section>
</Layout>

<style>
	.container {
		max-width: 800px;
		margin: 0 auto;
	}

	.breadcrumb {
		margin-bottom: var(--spacing-32);
	}

	.breadcrumb a {
		font-weight: var(--font-weight-medium);
	}

	.project-header {
		margin-bottom: var(--spacing-48);
	}

	.project-title {
		font-size: var(--font-size-800);
		margin-bottom: var(--spacing-16);
	}

	.project-description {
		font-size: var(--font-size-500);
		color: var(--color-base-gray-500);
		margin-bottom: var(--spacing-32);
		line-height: var(--font-line-height-relaxed);
	}

	.project-meta {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-24);
	}

	.tech-stack {
		display: flex;
		gap: var(--spacing-8);
		flex-wrap: wrap;
	}

	.tech-tag {
		background-color: var(--color-background-secondary);
		padding: var(--spacing-4) var(--spacing-12);
		border-radius: var(--spacing-4);
		font-size: var(--font-size-200);
		font-weight: var(--font-weight-medium);
	}

	.project-links {
		display: flex;
		gap: var(--spacing-16);
	}

	.divider {
		border: 0;
		border-top: 1px solid var(--color-base-gray-100);
		margin: var(--spacing-48) 0;
	}

	.project-content {
		font-size: var(--font-size-400);
		line-height: var(--font-line-height-relaxed);
		color: var(--color-text-primary);
	}

	.project-content :global(h2) {
		font-size: var(--font-size-600);
		margin: var(--spacing-48) 0 var(--spacing-24);
	}

	.project-content :global(p) {
		margin-bottom: var(--spacing-24);
	}

	.project-content :global(ul) {
		margin-bottom: var(--spacing-24);
		padding-left: var(--spacing-24);
	}

	.project-content :global(li) {
		margin-bottom: var(--spacing-8);
	}
</style>
