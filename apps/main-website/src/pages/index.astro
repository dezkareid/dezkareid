---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ServiceCard from "../components/ServiceCard.astro";
import SkillsList from "../components/SkillsList.astro";
import ContactSection from "../components/ContactSection.astro";

const featuredProjects = (
	await getCollection("projects", ({ data }) => {
		return data.featured === true;
	})
)
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 3);

const services = (await getCollection("services")).sort(
	(a, b) => a.data.order - b.data.order
);
---

<Layout title="Dezkareid - Frontend Architect">
	<Hero />
	<Section id="presentation">
		<div class="container">
			<div class="presentation-quote reveal">
				<p class="presentation-quote-text">
					"I like to solve problems and look back proud of what I've
					built. I'm a software developer who calls himself a Frontend
					Architect focused on React, Performance, and
					Maintainability."
				</p>
			</div>
		</div>
	</Section>

	<Section id="services" class="bg-alt">
		<div class="container">
			<header class="section-header reveal">
				<span class="section-label">Offerings</span>
				<h2 class="section-title">Services</h2>
			</header>
			<div class="grid reveal-group">
				{
					services.map((service) => (
						<div class="reveal">
							<ServiceCard service={service} />
						</div>
					))
				}
			</div>
		</div>
	</Section>

	<Section id="skills">
		<div class="container">
			<header class="section-header reveal">
				<span class="section-label">Tech Stack</span>
				<h2 class="section-title">Skills & Technologies</h2>
			</header>
			<div class="reveal">
				<SkillsList />
			</div>
		</div>
	</Section>

	<Section id="projects" class="bg-alt">
		<div class="container">
			<header class="section-header reveal">
				<span class="section-label">Work</span>
				<h2 class="section-title">Featured Projects</h2>
				<p class="section-intro">
					Some projects are personal, others are contributions, and
					others are part of my past work.
				</p>
			</header>
			<div class="grid reveal-group">
				{
					featuredProjects.map((project, i) => (
						<div class="reveal">
							<ProjectCard project={project} index={i} />
						</div>
					))
				}
			</div>
			<div class="section-actions reveal">
				<a href="/projects" class="view-all">
					<span>View All Projects</span>
					<span aria-hidden="true" class="view-all-arrow">→</span>
				</a>
			</div>
		</div>
	</Section>

	<ContactSection />
</Layout>

<script>
	/* Scroll-reveal using IntersectionObserver */
	const revealEls = document.querySelectorAll<HTMLElement>(".reveal");

	if (revealEls.length > 0) {
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add("is-visible");
						observer.unobserve(entry.target);
					}
				});
			},
			{ rootMargin: "0px 0px -60px 0px", threshold: 0.1 }
		);

		revealEls.forEach((el) => observer.observe(el));
	}
</script>

<style>
	/* ====================================================
	   DESIGN TOKEN ANNOTATIONS
	   - --section-label-color: mono muted text for eyebrow labels
	   - --section-title-size: --font-size-700 (already in scale)
	   ==================================================== */

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding-inline: var(--spacing-24);
	}

	@media (min-width: 90rem) {
		.container {
			padding-inline: 0;
		}
	}

	/* Section header: eyebrow label + title */
	.section-header {
		margin-bottom: var(--spacing-48);
	}

	.section-header--centered {
		text-align: center;
	}

	.section-label {
		display: block;
		font-size: var(--font-size-100);
		font-family: var(--font-family-mono);
		font-weight: var(--font-weight-medium);
		text-transform: uppercase;
		/* DS NOTE: --letter-spacing-wide: 0.08em candidate */
		letter-spacing: 0.1em;
		/* DS NOTE: --section-label-color candidate */
		color: var(--color-primary);
		margin-bottom: var(--spacing-8);
	}

	.section-title {
		font-size: var(--font-size-700);
		color: var(--color-text-primary);
		letter-spacing: -0.02em;
		line-height: var(--font-line-height-tight);
	}

	.section-intro {
		margin-top: var(--spacing-12);
		font-size: var(--font-size-300);
		color: var(--color-text-primary);
		opacity: 0.7;
		line-height: var(--font-line-height-relaxed);
	}

	/* Presentation quote */
	.presentation-quote {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: var(--spacing-8);
		max-width: 640px;
		margin-inline: auto;
	}

	.presentation-quote-text {
		font-size: clamp(1.125rem, 2.5vw, 1.375rem);
		font-weight: var(--font-weight-medium);
		color: var(--color-text-primary);
		line-height: var(--font-line-height-relaxed);
		letter-spacing: -0.01em;
		margin: 0;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: var(--spacing-32);
	}

	.section-actions {
		margin-top: var(--spacing-48);
	}

	.view-all {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-8);
		color: var(--color-primary);
		font-weight: var(--font-weight-bold);
		font-size: var(--font-size-400);
		text-decoration: none;
		border-bottom: 1px solid
			color-mix(in srgb, var(--color-primary) 40%, transparent);
		padding-bottom: 2px;
		transition: gap 0.2s ease, border-color 0.2s ease;
	}

	.view-all-arrow {
		transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.view-all:hover {
		text-decoration: none;
		gap: var(--spacing-12);
		border-color: var(--color-primary);
	}

	.view-all:hover .view-all-arrow {
		transform: translateX(4px);
	}

	.bg-alt {
		background-color: var(--color-background-secondary);
	}

	.text-center {
		text-align: center;
	}
</style>
