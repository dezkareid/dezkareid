---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import SkillsList from '../components/SkillsList.astro';
import ContactSection from '../components/ContactSection.astro';
---

<Layout title="About Me | Frontend Developer Portfolio">
	<Section>
		<div class="container">
			<h1 class="page-title">About Me</h1>
			<div class="about-content">
				<div class="about-text">
					<p>Hello! I'm a passionate Frontend Developer with a focus on building high-performance, accessible, and user-centric web applications. With years of experience in the React ecosystem, I enjoy solving complex problems and creating seamless digital experiences.</p>

					<p>My approach to development is grounded in clean code, robust architecture, and a deep understanding of web standards. I believe that a great website is not just about how it looks, but how it feels and performs for every user.</p>

					<p>When I'm not coding, you can find me exploring new technologies, contributing to open-source projects, or sharing my knowledge with the developer community.</p>
				</div>
				<div class="about-avatar">
					<img
						src="https://res.cloudinary.com/ddyovtxd2/image/upload/w_300,h_300,c_fill,g_face,q_auto,f_auto/v1773092115/JOEL_GOMEZ-4_viqymi.jpg"
						alt="Joel Gomez"
						class="avatar-img"
						width="300"
						height="300"
						loading="lazy"
						decoding="async"
					/>
				</div>
			</div>
		</div>
	</Section>

	<Section class="bg-alt">
		<div class="container">
			<header class="section-header">
				<span class="section-label">Tech Stack</span>
				<h2 class="section-title">My Technical Expertise</h2>
			</header>
			<SkillsList />
		</div>
	</Section>

	<ContactSection
		title="Let's Connect"
		description="I'm always open to discussing new projects, creative ideas, or opportunities to be part of your visions."
	/>
</Layout>

<style>
	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding-inline: var(--spacing-24);
	}

	@media (min-width: 90rem) {
		.container {
			padding-inline: 0;
		}
	}

	.page-title {
		font-size: var(--font-size-800);
		margin-bottom: var(--spacing-48);
		letter-spacing: -0.03em;
	}

	.about-content {
		display: grid;
		grid-template-columns: 1fr 300px;
		gap: var(--spacing-64);
		align-items: center;
	}

	.about-text p {
		font-size: var(--font-size-400);
		line-height: var(--font-line-height-relaxed);
		margin-bottom: var(--spacing-24);
		color: var(--color-text-primary);
	}

	.about-text p:last-child {
		margin-bottom: 0;
	}

	.about-avatar {
		flex-shrink: 0;
	}

	.avatar-img {
		width: 300px;
		height: 300px;
		border-radius: 50%;
		object-fit: cover;
		object-position: center top;
		display: block;
		border: 3px solid color-mix(in srgb, var(--color-primary) 30%, transparent);
	}

	/* Section headers */
	.section-header {
		margin-bottom: var(--spacing-48);
	}

	.section-label {
		display: block;
		font-size: var(--font-size-100);
		font-family: var(--font-family-mono);
		font-weight: var(--font-weight-medium);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-primary);
		margin-bottom: var(--spacing-8);
	}

	.section-title {
		font-size: var(--font-size-700);
		color: var(--color-text-primary);
		letter-spacing: -0.02em;
	}

	.bg-alt {
		background-color: var(--color-background-secondary);
	}

	@media (max-width: 800px) {
		.about-content {
			grid-template-columns: 1fr;
			text-align: center;
		}

		.about-avatar {
			order: -1;
		}

		.avatar-img {
			width: 200px;
			height: 200px;
			margin: 0 auto;
		}

		.about-text p {
			text-align: left;
		}
	}
</style>
