{
  "name": "@dezkareid/react-components",
  "version": "0.0.0",
  "description": "set of components with common functionalities",
  "keywords": [
    "react",
    "components"
  ],
  "type": "module",
  "sideEffects": false,
  "author": "Joel Humberto Gomez Paredes <elmaildeldezkareid@gmail.com>",
  "license": "MIT",
  "unpkg": "dist/browser",
  "main": "dist/cjs",
  "module": "dist/es",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run build:rollup && pnpm run build:webpack",
    "build:rollup": "rollup -c",
    "build:webpack": "webpack --config webpack/webpack.config.js",
    "start": "webpack serve --config webpack/webpack.dev.js",
    "lint": "eslint -c eslint.config.mjs .",
    "lint:fix": "pnpm run lint -- --fix",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dezkareid/dezkareid.git"
  },
  "bugs": {
    "url": "https://github.com/dezkareid/dezkareid/issues"
  },
  "engines": {
    "node": ">=22.17"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@dezkareid/react-hooks": "^1.2.0"
  },
  "devDependencies": {
    "@dezkareid/eslint-config-ts-base": "workspace:*",
    "@dezkareid/eslint-plugin-web": "workspace:*",
    "@rollup/plugin-commonjs": "29.0.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-terser": "0.4.4",
    "@rollup/plugin-typescript": "12.3.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.0.10",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "typescript-eslint": "8.57.0",
    "@vitejs/plugin-react": "5.1.2",
    "@vitest/ui": "4.0.18",
    "eslint": "9.39.2",
    "jsdom": "27.4.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rollup": "4.56.0",
    "rollup-plugin-cleaner": "1.0.0",
    "ts-loader": "9.5.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1",
    "webpack-dev-server": "5.2.3",
    "webpack-merge": "6.0.1"
  }
}